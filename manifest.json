{
  "manifest_version": 3,
  "name": "Job Applier PRO AI",
  "version": "2.0",
  "description": "Professional AI-powered job automation system for LinkedIn and Gmail.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://mail.google.com/*",
    "https://gmail.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Job Applier PRO"
  },
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*"],
      "js": ["scripts/content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/dashboard/index.html"
      ],
      "matches": ["https://*.linkedin.com/*"]
    }
  ]
}
